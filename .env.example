# ==============================================
# AlgorithmShift Platform - Environment Settings
# Managed keys are rewritten on every sandbox resume + config change.
# User-added keys (below) are preserved across writes.
# ==============================================

# Database Configuration
# ----------------------
ENABLE_DATABASE=your-enable-database-here
DATABASE_URL=your-database-url-here
DATABASE_TYPE=your-database-type-here
PUBLIC_SIGNUP_ENABLED=your-public-signup-enabled-here

# Integration API Keys (from platform config)
# -------------------------------------------
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=your-nextauth-url-here
AUTH_URL=your-auth-url-here
AUTH_SECRET=your-auth-secret-here

# User-added Environment Variables (preserved)
# ---------------------------------------------
STRIPE_SECRET_KEY=your-stripe-secret-key-here
STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key-here
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret-here
